---
// Project / experience summary card used on the home page.
interface Props {
  href: string;
  title: string;
  blurb?: string;
  image?: string;
  tools?: string[];
}
const { href, title, blurb, image, tools = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isLogo = image?.includes('logo');
---

<a class="card reveal" href={href}>
  {image && <img class={`card-media ${isLogo ? 'is-logo' : ''}`} src={`${base}${image}`} alt={title} loading="lazy" />}
  <h3>{title}</h3>
  {blurb && <p>{blurb}</p>}
  {tools.length > 0 && (
    <div class="card-tools">
      {tools.map((t) => <span class="chip">{t}</span>)}
    </div>
  )}
  <span class="card-cta">View details →</span>
</a>
