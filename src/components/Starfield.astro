---
// Lightweight canvas starfield. Sits behind the hero, fixed to the viewport.
// No dependencies; pauses when the tab is hidden and disables motion when the
// user prefers reduced motion.
---

<canvas id="starfield" aria-hidden="true"></canvas>

<style>
  #starfield {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
    /* fade the field toward the bottom so content stays legible */
    mask-image: linear-gradient(to bottom, #000 0%, #000 55%, transparent 95%);
  }
</style>

<script>
  const canvas = document.getElementById('starfield') as HTMLCanvasElement | null;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;
    let w = 0, h = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);
    let stars: { x: number; y: number; z: number; r: number }[] = [];
    let pointerX = 0, pointerY = 0;

    function resize() {
      w = canvas!.clientWidth;
      h = canvas!.clientHeight;
      canvas!.width = Math.floor(w * dpr);
      canvas!.height = Math.floor(h * dpr);
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const count = Math.min(220, Math.floor((w * h) / 7000));
      stars = Array.from({ length: count }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        z: Math.random() * 0.8 + 0.2, // depth: drives size, speed, brightness
        r: 0,
      }));
    }

    function draw(drift: number) {
      ctx.clearRect(0, 0, w, h);
      for (const s of stars) {
        const size = s.z * 1.6;
        const px = s.x + pointerX * s.z * 18;
        const py = s.y + pointerY * s.z * 18 + drift * s.z;
        const yy = ((py % h) + h) % h;
        ctx.beginPath();
        ctx.arc(px, yy, size, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${180 + s.z * 60}, ${210 + s.z * 30}, 255, ${0.25 + s.z * 0.5})`;
        ctx.fill();
      }
    }

    resize();
    window.addEventListener('resize', resize);

    if (reduce) {
      draw(0); // static field, no animation loop
    } else {
      window.addEventListener('pointermove', (e) => {
        pointerX = (e.clientX / window.innerWidth - 0.5) * 2;
        pointerY = (e.clientY / window.innerHeight - 0.5) * 2;
      });
      let t = 0, running = true;
      document.addEventListener('visibilitychange', () => {
        running = !document.hidden;
        if (running) loop();
      });
      function loop() {
        if (!running) return;
        t += 0.15;
        draw(t);
        requestAnimationFrame(loop);
      }
      loop();
    }
  }
</script>
