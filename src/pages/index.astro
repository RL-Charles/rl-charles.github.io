---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Starfield from '../components/Starfield.astro';
import Card from '../components/Card.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const experience = (await getCollection('experience')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base>
  <Starfield />

  <header class="hero">
    <div class="wrap">
      <p class="eyebrow">Software Engineer · Backend · Hardware · AI</p>
      <h1>Charles Mowbray</h1>
      <p class="hero-lede">
        I build full-stack applications, device-communication tooling, and the
        infrastructure that tests hardware before it ships. This is a collection
        of my work and projects.
      </p>
      <div class="hero-actions">
        <a class="btn" href="#experience">Experience</a>
        <a class="btn" href="#projects">Projects</a>
        <a class="btn" href="https://github.com/RL-Charles">GitHub ↗</a>
        <a class="btn" href="https://www.linkedin.com/in/charles-mowbray">LinkedIn ↗</a>
      </div>
    </div>
  </header>

  <main class="wrap">
    <h2 class="section-title" id="experience"> Work Experience</h2>
    <div class="card-grid">
      {experience.map((e) => (
        <Card
          href={`${base}/experience/${e.id}/`}
          title={e.data.role ?? e.data.title}
          blurb={e.data.company}
          image={e.data.image}
          tools={e.data.tools}
        />
      ))}
    </div>

    <h2 class="section-title" id="projects"> Projects</h2>
    <div class="card-grid">
      {projects.map((p) => (
        <Card
          href={`${base}/projects/${p.id}/`}
          title={p.data.title}
          blurb={p.data.subtitle}
          image={p.data.image}
          tools={p.data.tools}
        />
      ))}
    </div>
  </main>
</Base>

<style>
  .hero {
    padding: clamp(5rem, 16vh, 9rem) 0 2rem;
    position: relative;
  }
  .hero h1 {
    font-size: clamp(2.6rem, 8vw, 4.5rem);
    margin: 0.5rem 0 1rem;
    background: linear-gradient(180deg, #ffffff, #9fb4cc);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-lede {
    max-width: 38rem;
    color: var(--text-dim);
    font-size: 1.1rem;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.75rem;
  }
</style>
