---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const experience = await getCollection('experience');
  return experience.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, role, company, tools, logo, skills, lead_image, lead_image_alt } =
  entry.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title={`${role ?? title} — Charles Mowbray`} description={title}>
  <main class="wrap article">
    <a class="back" href={`${base}/`}>← Back to portfolio</a>

    <article class="prose reveal is-visible">
      <p class="eyebrow">Experience</p>
      {logo && <img class="logo" src={`${base}${logo}`} alt={company ?? title} />}
      <h1>{role ?? title}</h1>
      {company && <p class="article-sub">{company}</p>}

      <div class="exp-lead">
        {skills ? (
          <div class="skill-grid">
            {skills.map((s) => (
              <div class="skill-group">
                <span class="skill-label">{s.group}</span>
                <div class="skill-chips">
                  {s.items.map((i) => <span class="chip">{i}</span>)}
                </div>
              </div>
            ))}
          </div>
        ) : tools.length > 0 ? (
          <div class="card-tools">
            {tools.map((t) => <span class="chip">{t}</span>)}
          </div>
        ) : null}
      </div>

      <hr />
      <Content />

      {lead_image && (
        <img
          class="exp-footer-media"
          src={`${base}${lead_image}`}
          alt={lead_image_alt ?? `${company ?? title} hardware`}
          loading="lazy"
        />
      )}
    </article>
  </main>
</Base>

<style>
  .article { padding-top: 3rem; max-width: 880px; }
  .article-sub { color: var(--text-dim); font-size: 1.1rem; margin: 0; }
  .logo { max-height: 60px; width: auto; border: 0 !important; margin: 0 0 1rem !important; }

  /* Lead block: categorized skills, full width. */
  .exp-lead {
    margin: 1.5rem 0 0.5rem;
  }

  .skill-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.1rem 1.5rem;
  }
  .skill-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }
  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  /* Hardware image at the foot of the page — natural aspect ratio, no cropping. */
  .exp-footer-media {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    display: block;
    margin: 2.5rem auto 0;
  }

  @media (max-width: 480px) {
    .skill-grid { grid-template-columns: 1fr; }
  }
</style>
