---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, subtitle, tools, github_repo } = entry.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Base title={`${title} — Charles Mowbray`} description={subtitle}>
  <main class="wrap article">
    <a class="back" href={`${base}/`}>← Back to portfolio</a>

    <article class="prose reveal is-visible">
      <p class="eyebrow">Project</p>
      <h1>{title}</h1>
      {subtitle && <p class="article-sub">{subtitle}</p>}

      {tools.length > 0 && (
        <div class="card-tools" style="margin: 1rem 0 0.5rem;">
          {tools.map((t) => <span class="chip">{t}</span>)}
        </div>
      )}
      {github_repo && (
        <p><a class="btn" href={github_repo}>View on GitHub ↗</a></p>
      )}

      <hr />
      <Content />
    </article>
  </main>
</Base>

<style>
  .article { padding-top: 3rem; max-width: 880px; }
  .article-sub { color: var(--text-dim); font-size: 1.1rem; margin: 0; }
</style>
