---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Charles Mowbray — Software Engineer",
  description = "Portfolio of Charles Mowbray — fullstack, hardware, and AI-focused software engineering.",
} = Astro.props;

const base = import.meta.env.BASE_URL; // "/" for the user Pages site
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0e16" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2222%22 fill=%22%230d131f%22 stroke=%22%231f2a3a%22 stroke-width=%224%22/><text x=%2220%22 y=%2270%22 font-family=%22monospace%22 font-size=%2264%22 fill=%22%2336d6e7%22 font-weight=%22bold%22>&gt;_</text></svg>">

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Roboto+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />

    <footer class="site-footer">
      <div class="wrap">
        <span>Charles Mowbray · Software Engineer</span>
        <span>Location: Denver, CO</span>
        <span>Contact: <a href="mailto:charleswdmowbray@gmail.com">charleswdmowbray@gmail.com</a></span>
        <span><a href="https://www.linkedin.com/in/charles-mowbray">LinkedIn</a> · <a href="https://github.com/RL-Charles">GitHub</a></span>
      </div>
    </footer>

    <script>
      // Progressive scroll-reveal — opt-in via the `.reveal` class.
      const els = document.querySelectorAll<HTMLElement>('.reveal');
      if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12 }
        );
        els.forEach((el) => io.observe(el));
      } else {
        els.forEach((el) => el.classList.add('is-visible'));
      }
    </script>
  </body>
</html>
